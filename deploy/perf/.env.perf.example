SECRET_KEY=replace-with-a-beta-secret
ADMIN_USERNAME=admin-perf
ADMIN_PASSWORD=replace-with-a-beta-password

# Keep alerts disabled in beta by default so test failures do not page production channels.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=
SMTP_USE_SSL=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
ALERT_WEBHOOK_URL=

MAX_UPLOAD_SIZE_MB=50
FAILURE_RETENTION_DAYS=14
FAILURE_MAX_SIZE_MB=512

# Keep runtime state isolated from production.
AUDIT_DB_PATH=/app/data/conversion_audit.sqlite3
FAILURE_ROOT=/app/failed_uploads
UPLOAD_ROOT=/app/upload_tmp

# Enable performance instrumentation only for the beta instance.
PERF_TIMING_ENABLED=true
